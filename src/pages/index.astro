<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>GlassBee Solutions — Web Design & Growth Partner · San Diego</title>
<meta name="description" content="I help local businesses, nonprofits, and brands grow online with beautiful websites and organic search that actually books work. See recent work and a verified case study." />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet" />
<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink:     #0D0D0D;
    --ink2:    #1A1A1A;
    --paper:   #FAF7F2;
    --muted:   #6B6860;
    --faint:   #E8E4DC;
    --gold:    #C9922A;
    --gold-lt: #F5D99A;
    --green:   #2A7A4B;
    --green-lt:#D4EDDF;
    --orange:  #FF6B35;
    --serif:   'Playfair Display', Georgia, serif;
    --sans:    'DM Sans', system-ui, sans-serif;
    --rule:    1px solid var(--faint);
  }

  html { scroll-behavior: smooth; }
  body {
    font-family: var(--sans);
    background: var(--paper);
    color: var(--ink);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .page { max-width: 980px; margin: 0 auto; padding: 0 32px; }
  .narrow { max-width: 680px; }

  a { color: inherit; }

  /* HEADER */
  header {
    padding: 32px 0 26px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    border-bottom: var(--rule);
  }
  .logo { text-decoration: none; display: flex; flex-direction: column; }
  .logo .l1 { font-family: 'Bebas Neue', sans-serif; font-size: 27px; color: var(--ink); letter-spacing: 0.1em; line-height: 1; }
  .logo .l2 { font-family: 'Poppins', sans-serif; font-size: 9px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--orange); margin-top: -1px; }
  .nav { display: flex; align-items: center; gap: 28px; }
  .nav a { font-size: 15px; color: var(--muted); text-decoration: none; font-weight: 500; transition: color 0.15s; }
  .nav a:hover { color: var(--ink); }
  .nav a.cta { color: var(--ink); font-weight: 600; }
  @media (max-width: 560px) { .nav { gap: 18px; } .nav a.hide-sm { display: none; } }

  /* HERO */
  .hero { padding: 96px 0 80px; text-align: center; }
  .eyebrow {
    font-size: 13px; font-weight: 600; letter-spacing: 2px;
    text-transform: uppercase; color: var(--gold); margin-bottom: 26px;
  }
  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(40px, 6.5vw, 76px);
    font-weight: 900; line-height: 1.04; letter-spacing: -2px;
    color: var(--ink); margin: 0 auto 30px; max-width: 880px;
  }
  .hero h1 em { font-style: italic; color: var(--gold); }
  .hero-sub {
    font-size: 20px; color: var(--muted); line-height: 1.75;
    max-width: 600px; margin: 0 auto 44px; font-weight: 400;
  }
  .hero-sub strong { color: var(--ink); font-weight: 600; }
  .hero-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* BUTTONS */
  .btn-primary {
    background: var(--orange); color: #fff;
    font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 15px;
    text-transform: uppercase; letter-spacing: 0.05em;
    padding: 17px 38px; border-radius: 8px; text-decoration: none;
    display: inline-block; border: 2px solid var(--orange);
    transition: background 0.15s, border-color 0.15s, transform 0.12s;
  }
  .btn-primary:hover { background: #E55527; border-color: #E55527; transform: translateY(-1px); }
  .btn-secondary {
    background: transparent; color: var(--ink); font-weight: 500; font-size: 15px;
    padding: 17px 34px; border-radius: 8px; text-decoration: none;
    display: inline-block; border: 1px solid var(--faint);
    transition: background 0.15s, transform 0.12s;
  }
  .btn-secondary:hover { background: var(--faint); transform: translateY(-1px); }

  /* SECTION */
  section { padding: 72px 0; border-top: var(--rule); }
  .sec-head { margin-bottom: 40px; }
  .sec-head.center { text-align: center; }
  h2 {
    font-family: var(--serif); font-size: clamp(28px, 4vw, 42px);
    font-weight: 700; line-height: 1.15; letter-spacing: -0.8px; color: var(--ink);
  }
  .sec-sub { font-size: 17px; color: var(--muted); line-height: 1.8; margin-top: 14px; max-width: 620px; }
  .sec-head.center .sec-sub { margin-left: auto; margin-right: auto; }

  /* FEATURED CASE STUDY */
  .featured {
    display: block; text-decoration: none;
    background: var(--ink); color: var(--paper);
    border-radius: 18px; padding: 52px 48px; position: relative; overflow: hidden;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .featured:hover { transform: translateY(-3px); box-shadow: 0 24px 60px rgba(13,13,13,0.22); }
  .featured::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--gold), var(--orange));
  }
  .featured-tag {
    font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--gold-lt); margin-bottom: 18px;
  }
  .featured-big {
    font-family: var(--serif); font-size: clamp(44px, 7vw, 76px);
    font-weight: 900; letter-spacing: -2.5px; line-height: 1; color: var(--paper); margin-bottom: 8px;
  }
  .featured-big span { color: var(--gold-lt); }
  .featured-line { font-size: 18px; color: rgba(250,247,242,0.78); line-height: 1.7; max-width: 560px; margin-bottom: 28px; }
  .featured-line strong { color: var(--paper); font-weight: 600; }
  .featured-row { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; }
  .featured-link {
    font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 15px;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink);
    background: var(--gold-lt); padding: 15px 30px; border-radius: 8px;
    transition: transform 0.12s, background 0.15s;
  }
  .featured:hover .featured-link { background: #fff; }
  .featured-meta { display: flex; gap: 18px; font-size: 14px; color: rgba(250,247,242,0.55); flex-wrap: wrap; }
  .featured-meta span { display: flex; align-items: center; gap: 7px; }
  @media (max-width: 560px) { .featured { padding: 36px 26px; } }

  /* WORK GROUPS */
  .work-group { margin-top: 44px; }
  .work-group:first-of-type { margin-top: 0; }
  .group-label {
    font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 20px; display: flex; align-items: center; gap: 12px;
  }
  .group-label::after { content: ''; flex: 1; height: 1px; background: var(--faint); }

  .work-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 760px) { .work-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .work-grid { grid-template-columns: 1fr; } }

  .work-card {
    display: flex; flex-direction: column; justify-content: space-between;
    text-decoration: none; color: var(--ink);
    border: var(--rule); border-radius: 14px; padding: 26px 24px; min-height: 168px;
    background: #fff; position: relative; overflow: hidden;
    transition: transform 0.16s, box-shadow 0.16s, border-color 0.16s;
  }
  .work-card:hover { transform: translateY(-3px); box-shadow: 0 16px 38px rgba(13,13,13,0.10); border-color: var(--gold-lt); }
  .work-mono {
    font-family: var(--serif); font-size: 30px; font-weight: 900; line-height: 1;
    width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center;
    background: rgba(201,146,42,0.10); color: var(--gold); margin-bottom: 20px;
  }
  .work-name { font-family: var(--serif); font-size: 21px; font-weight: 700; letter-spacing: -0.4px; line-height: 1.2; margin-bottom: 4px; }
  .work-domain { font-size: 13px; color: var(--muted); display: flex; align-items: center; gap: 6px; }
  .work-domain .arrow { color: var(--gold); transition: transform 0.16s; }
  .work-card:hover .work-domain .arrow { transform: translate(2px,-2px); }

  /* APPROACH STRIP */
  .approach { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 700px) { .approach { grid-template-columns: 1fr; } }
  .approach-card { border: var(--rule); border-radius: 14px; padding: 28px 26px; background: #fff; }
  .approach-card h3 { font-family: var(--serif); font-size: 20px; font-weight: 700; margin-bottom: 10px; }
  .approach-card p { font-size: 15px; color: var(--muted); line-height: 1.7; }

  /* MISSION */
  .mission {
    background: var(--ink); color: var(--paper); border-radius: 18px;
    padding: 56px 52px; position: relative; overflow: hidden;
  }
  .mission::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--gold), var(--orange));
  }
  .mission .eyebrow { color: var(--gold-lt); }
  .mission blockquote {
    font-family: var(--serif); font-size: clamp(20px, 2.6vw, 27px);
    font-weight: 700; font-style: italic; line-height: 1.5; color: var(--paper); max-width: 760px;
  }
  .mission cite { display: block; margin-top: 24px; font-size: 15px; color: var(--gold-lt); font-style: normal; font-weight: 600; }
  @media (max-width: 560px) { .mission { padding: 38px 28px; } }

  /* CLOSING CTA */
  .closing { text-align: center; padding: 96px 0; border-top: var(--rule); }
  .closing h2 { max-width: 620px; margin: 0 auto 22px; }
  .closing p { font-size: 17px; color: var(--muted); max-width: 460px; margin: 0 auto 38px; line-height: 1.7; }
  .closing-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .closing-note { font-size: 14px; color: var(--muted); margin-top: 22px; }

  /* FOOTER */
  footer {
    padding: 30px 0; border-top: var(--rule);
    display: flex; justify-content: space-between; align-items: center;
    font-size: 13px; color: var(--muted); flex-wrap: wrap; gap: 12px;
  }

  @media (max-width: 560px) {
    .page { padding: 0 20px; }
    .hero { padding: 60px 0 52px; }
    section { padding: 52px 0; }
    .closing { padding: 64px 0; }
    .hero-actions, .closing-actions { flex-direction: column; align-items: stretch; }
    .btn-primary, .btn-secondary { text-align: center; }
    footer { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
</head>
<body>

<div class="page">

  <!-- HEADER -->
  <header>
    <a href="/" class="logo">
      <span class="l1">GLASSBEE</span>
      <span class="l2">Solutions</span>
