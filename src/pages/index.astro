<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>GlassBee Solutions — Web Design & Growth Partner · San Diego</title>
<meta name="description" content="I help local businesses, nonprofits, and brands grow online with beautiful websites and organic search that actually books work. See recent work and a verified case study." />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet" />
<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0B0C0E;
    --panel:    #131519;
    --panel-2:  #1A1D24;
    --line:     rgba(245,240,232,0.09);
    --line-2:   rgba(245,240,232,0.16);
    --text:     #F5F0E8;
    --muted:    rgba(245,240,232,0.60);
    --faint:    rgba(245,240,232,0.40);
    --gold:     #D7A33E;
    --gold-lt:  #F3D89A;
    --orange:   #FF6B35;
    --green:    #5BD08A;
    --serif:    'Playfair Display', Georgia, serif;
    --sans:     'DM Sans', system-ui, sans-serif;
    --ease:     cubic-bezier(0.16, 1, 0.3, 1);
    --accent:   linear-gradient(135deg, var(--gold) 0%, var(--orange) 100%);
  }

  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  a { color: inherit; text-decoration: none; }

  .page { max-width: 1020px; margin: 0 auto; padding: 0 32px; }

  /* MOTION SYSTEM (adapted from Severin Detailing + Green Means Give) */
  .reveal, .reveal-l, .reveal-r {
    opacity: 0;
    transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
    will-change: opacity, transform;
  }
  .reveal   { transform: translateY(22px); }
  .reveal-l { transform: translateX(-26px); }
  .reveal-r { transform: translateX(26px); }
  .reveal.is-visible, .reveal-l.is-visible, .reveal-r.is-visible { opacity: 1; transform: none; }
  .d1 { transition-delay: 0.08s; }
  .d2 { transition-delay: 0.16s; }
  .d3 { transition-delay: 0.24s; }
  .d4 { transition-delay: 0.32s; }
  @media (prefers-reduced-motion: reduce) {
    .reveal, .reveal-l, .reveal-r { transition: none; opacity: 1; transform: none; }
    html { scroll-behavior: auto; }
  }

  .arrow-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-weight: 600; color: var(--gold-lt);
    transition: gap 0.2s var(--ease), color 0.2s var(--ease);
  }
  .arrow-link::after { content: '→'; transition: transform 0.2s var(--ease); }
  .arrow-link:hover { color: #fff; }
  .arrow-link:hover::after { transform: translateX(5px); }

  /* BUTTONS */
  .btn-primary {
    position: relative; display: inline-block;
    background: var(--accent); color: #1A1206;
    font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 14.5px;
    text-transform: uppercase; letter-spacing: 0.05em;
    padding: 16px 34px; border-radius: 9px;
    transition: transform 0.15s var(--ease), box-shadow 0.3s var(--ease);
    box-shadow: 0 6px 26px rgba(255,107,53,0.28);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 38px rgba(255,107,53,0.45); }
  .btn-ghost {
    display: inline-block; color: var(--text); font-weight: 500; font-size: 14.5px;
    padding: 16px 30px; border-radius: 9px; border: 1px solid var(--line-2);
    transition: background 0.18s var(--ease), border-color 0.18s var(--ease), transform 0.15s var(--ease);
  }
  .btn-ghost:hover { background: rgba(245,240,232,0.05); border-color: var(--gold); transform: translateY(-2px); }

  /* HEADER */
  header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(11,12,14,0.72);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s var(--ease), background 0.3s var(--ease);
  }
  header.scrolled { border-bottom-color: var(--line); background: rgba(11,12,14,0.9); }
  .nav-inner {
    max-width: 1020px; margin: 0 auto; padding: 18px 32px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
  }
  .logo { display: flex; flex-direction: column; }
  .logo .l1 { font-family: 'Bebas Neue', sans-serif; font-size: 26px; letter-spacing: 0.1em; line-height: 1; color: var(--text); }
  .logo .l2 { font-family: 'Poppins', sans-serif; font-size: 8.5px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--orange); margin-top: -1px; }
  .nav { display: flex; align-items: center; gap: 26px; }
  .nav a { font-size: 14.5px; color: var(--muted); font-weight: 500; transition: color 0.15s; }
  .nav a:hover { color: var(--text); }
  .nav a.book {
    color: #1A1206; background: var(--gold-lt); padding: 9px 18px; border-radius: 7px; font-weight: 600;
    transition: transform 0.15s var(--ease), background 0.15s;
  }
  .nav a.book:hover { background: #fff; transform: translateY(-1px); }
  @media (max-width: 560px) { .nav { gap: 16px; } .nav a.hide-sm { display: none; } }

  /* HERO */
  .hero { position: relative; overflow: hidden; }
  .hero-aurora {
    position: absolute; inset: -20% -10% auto -10%; height: 130%;
    pointer-events: none; z-index: 0; opacity: 0.9;
    background:
      radial-gradient(40% 50% at 22% 18%, rgba(215,163,62,0.20) 0%, transparent 60%),
      radial-gradient(38% 46% at 82% 30%, rgba(255,107,53,0.16) 0%, transparent 62%),
      radial-gradient(46% 50% at 60% 85%, rgba(91,208,138,0.07) 0%, transparent 60%);
    animation: drift 22s var(--ease) infinite alternate;
  }
  @keyframes drift {
    0%   { transform: translate3d(0,0,0) scale(1); }
    100% { transform: translate3d(-3%, 2%, 0) scale(1.08); }
  }
  .hero-glow {
    position: absolute; top: 0; left: 0; z-index: 1; pointer-events: none;
    width: 560px; height: 560px; border-radius: 50%;
    background: radial-gradient(circle, rgba(243,216,154,0.16) 0%, rgba(255,107,53,0.07) 40%, transparent 70%);
    transform: translate(-50%, -50%); opacity: 0;
    transition: opacity 0.5s var(--ease); will-change: transform; mix-blend-mode: screen;
  }
  @media (hover: none) { .hero-glow { display: none; } }
  .hero-inner { position: relative; z-index: 2; padding: 104px 0 84px; text-align: center; }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 12.5px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 28px;
  }
  .eyebrow::before, .eyebrow::after { content: ''; width: 26px; height: 1px; background: var(--gold); opacity: 0.5; }
  .hero h1 {
    font-family: var(--serif); font-weight: 900;
    font-size: clamp(42px, 7vw, 82px); line-height: 1.02; letter-spacing: -2px;
    margin: 0 auto 28px; max-width: 900px;
  }
  .hero h1 em { font-style: italic; color: transparent; background: var(--accent); -webkit-background-clip: text; background-clip: text; }
  .hero-sub { font-size: 19.5px; color: var(--muted); line-height: 1.75; max-width: 600px; margin: 0 auto 42px; }
  .hero-sub strong { color: var(--text); font-weight: 600; }
  .hero-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* MARQUEE */
  .marquee { position: relative; z-index: 2; margin-top: 18px; padding: 22px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
            mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
    overflow: hidden; }
  .marquee-track { display: flex; gap: 0; width: max-content; animation: marquee 34s linear infinite; }
  .marquee:hover .marquee-track { animation-play-state: paused; }
  .marquee-item { display: inline-flex; align-items: center; gap: 16px; padding: 0 28px; font-family: var(--serif); font-style: italic; font-size: 19px; color: var(--faint); white-space: nowrap; }
  .marquee-item::before { content: '✦'; font-style: normal; font-size: 11px; color: var(--gold); }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .marquee-track { animation: none; } .hero-aurora { animation: none; } }

  /* SECTION */
  section { padding: 84px 0; border-top: 1px solid var(--line); }
  .sec-head { margin-bottom: 44px; }
  .sec-head.center { text-align: center; }
  .sec-eyebrow { font-size: 12.5px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; }
  h2 { font-family: var(--serif); font-size: clamp(30px, 4.4vw, 46px); font-weight: 700; line-height: 1.12; letter-spacing: -1px; }
  .sec-sub { font-size: 17px; color: var(--muted); line-height: 1.75; margin-top: 14px; max-width: 600px; }
  .sec-head.center .sec-sub { margin-left: auto; margin-right: auto; }

  /* WHAT I DO */
  .do-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 760px) { .do-grid { grid-template-columns: 1fr; } }
  .do-card {
    position: relative; background: var(--panel); border: 1px solid var(--line);
    border-radius: 16px; padding: 34px 30px; overflow: hidden;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .do-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--accent); opacity: 0; transition: opacity 0.25s var(--ease); }
  .do-card:hover { transform: translateY(-6px); border-color: var(--line-2); box-shadow: 0 22px 50px rgba(0,0,0,0.45); }
  .do-card:hover::before { opacity: 1; }
  .do-icon {
    width: 52px; height: 52px; border-radius: 13px; display: flex; align-items: center; justify-content: center;
    background: rgba(215,163,62,0.12); border: 1px solid rgba(215,163,62,0.25); margin-bottom: 22px;
  }
  .do-icon svg { width: 24px; height: 24px; stroke: var(--gold-lt); }
  .do-card h3 { font-family: var(--serif); font-size: 22px; font-weight: 700; margin-bottom: 10px; }
  .do-card p { font-size: 15px; color: var(--muted); line-height: 1.7; }

  /* RECENT WORK */
  .work-group { margin-top: 42px; }
  .work-group:first-of-type { margin-top: 0; }
  .group-label { font-size: 12.5px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; display: flex; align-items: center; gap: 14px; }
  .group-label::after { content: ''; flex: 1; height: 1px; background: var(--line); }
  .work-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 820px) { .work-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .work-grid { grid-template-columns: 1fr; } }

  .work-card {
    display: flex; flex-direction: column; position: relative; overflow: hidden;
    background: var(--panel); border: 1px solid var(--line); border-radius: 16px; padding: 26px 24px; min-height: 210px;
    transition: transform 0.22s var(--ease), border-color 0.22s var(--ease), box-shadow 0.22s var(--ease);
  }
  .work-card::after { content: ''; position: absolute; inset: 0; border-radius: 16px; pointer-events: none; box-shadow: inset 0 0 0 1px transparent; transition: box-shadow 0.22s var(--ease); }
  .work-card:hover { transform: translateY(-6px); border-color: transparent; box-shadow: 0 22px 50px rgba(0,0,0,0.5); }
  .work-card:hover::after { box-shadow: inset 0 0 0 1px var(--gold); }
  .work-top { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
  .work-mono {
    font-family: var(--serif); font-size: 24px; font-weight: 900; line-height: 1;
    width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;
    color: #1A1206; background: var(--accent); flex-shrink: 0;
  }
  .work-name { font-family: var(--serif); font-size: 20px; font-weight: 700; letter-spacing: -0.4px; line-height: 1.15; }
  .work-cat { font-size: 11.5px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--faint); margin-top: 3px; }
  .work-blurb { font-size: 14px; color: var(--muted); line-height: 1.6; flex: 1; }
  .work-visit { margin-top: 18px; font-size: 13.5px; }

  /* CASE STUDY STRIP (compact) */
  .cs-strip {
    position: relative; overflow: hidden; display: flex; align-items: center; justify-content: space-between;
    gap: 28px; flex-wrap: wrap;
    background: var(--panel-2); border: 1px solid var(--line-2); border-radius: 16px; padding: 30px 36px;
    transition: border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .cs-strip::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--accent); }
  .cs-strip:hover { border-color: var(--gold); box-shadow: 0 18px 44px rgba(0,0,0,0.4); }
  .cs-tag { font-size: 11.5px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
  .cs-line { font-family: var(--serif); font-size: clamp(20px, 2.6vw, 26px); font-weight: 700; line-height: 1.3; max-width: 560px; }
  .cs-line b { color: transparent; background: var(--accent); -webkit-background-clip: text; background-clip: text; }
  .cs-meta { font-size: 13.5px; color: var(--muted); margin-top: 10px; }
  @media (max-width: 560px) { .cs-strip { padding: 26px 24px; } }

  /* MISSION */
  .mission { position: relative; overflow: hidden; background: linear-gradient(160deg, var(--panel-2), var(--panel)); border: 1px solid var(--line); border-radius: 20px; padding: 56px 52px; }
  .mission::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--accent); }
  .mission .sec-eyebrow { color: var(--gold-lt); }
  .mission blockquote { font-family: var(--serif); font-size: clamp(20px, 2.5vw, 27px); font-weight: 700; font-style: italic; line-height: 1.5; max-width: 780px; }
  .mission cite { display: block; margin-top: 24px; font-size: 15px; color: var(--gold-lt); font-style: normal; font-weight: 600; }
  @media (max-width: 560px) { .mission { padding: 38px 26px; } }

  /* CLOSING */
  .closing { text-align: center; padding: 100px 0; }
  .closing h2 { max-width: 640px; margin: 0 auto 20px; }
  .closing p { font-size: 17px; color: var(--muted); max-width: 470px; margin: 0 auto 38px; line-height: 1.7; }
  .closing-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .closing-note { font-size: 13.5px; color: var(--faint); margin-top: 22px; letter-spacing: 0.3px; }

  /* FOOTER */
  footer { padding: 28px 0 56px; border-top: 1px solid var(--line); display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: var(--faint); flex-wrap: wrap; gap: 12px; }
  footer a { color: var(--muted); transition: color 0.15s; }
  footer a:hover { color: var(--text); }

  @media (max-width: 560px) {
    .page { padding: 0 20px; }
    .nav-inner { padding: 16px 20px; }
    .hero-inner { padding: 70px 0 56px; }
    section { padding: 60px 0; }
    .closing { padding: 70px 0; }
    .hero-actions, .closing-actions { flex-direction: column; align-items: stretch; }
    .btn-primary, .btn-ghost { text-align: center; }
    footer { flex-direction: column; gap: 8px; text-align: center; justify-content: center; }
  }
</style>
</head>
